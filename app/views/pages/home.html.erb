<H1>Bienvenue</H1>

<div>
  <% if user_signed_in? %>
    <p>Vous êtes connecté en tant que <%= current_user.email %></p>
    <%= link_to "Déconnexion", destroy_user_session_path, method: :delete %>
  <% else %>
    <%= link_to "Connexion", new_user_session_path %>
  <% end %>
</div>

<div>
  <% if user_signed_in? %>
    <%= link_to "Mes organisations", user_organisations_path(current_user) %>
  <% end %>
</div>
